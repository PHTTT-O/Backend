@startuml
title Delete Restaurant (DELETE /api/v1/restaurants/{id})

participant "Client" as client
participant "<<Controller>>\ndeleteRestaurant()" as controller
participant "<<Model>>\nRestaurant" as model
database "<<MongoDB>>\nrestaurants" as db

client -> controller : DELETE /restaurants/{id}
activate controller

controller -> model : findById(id)
activate model
model --> controller : restaurant / null
deactivate model

alt restaurant not found
  controller --> client : 404 Restaurant not found
else restaurant exists
  controller -> model : deleteOne()
  activate model
  model -> db : delete document
  deactivate model

  controller --> client : 200 OK
end

deactivate controller
@enduml